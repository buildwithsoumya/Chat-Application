# ChatSphere Backend — Environment Variables
# Copy this file to .env and fill in the values.

# PostgreSQL / Supabase connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing secret — generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-random-secret-key

# JWT algorithm (HS256 recommended)
ALGORITHM=HS256

# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS allowed origins (comma-separated). Defaults to localhost:5173 if not set.
# CORS_ORIGINS=https://your-production-domain.com,https://www.your-production-domain.com
